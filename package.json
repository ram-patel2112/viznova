{
  "name": "viznova",
  "version": "1.0.0",
  "description": "VizNova is a full-stack platform that automatically analyzes datasets, generates visualizations, and provides predictive insights using rule-based algorithms.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "frontend": "npm run dev --prefix frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
